---
// No props — uses slot for the formula content
---

<div class="formula not-content">
  <slot />
</div>

<style>
  .formula {
    font-family: var(--sl-font-mono);
    font-size: 0.95rem;
    background: var(--sl-color-gray-6, #1E1D1B);
    border: 1px solid rgba(232, 145, 58, 0.08);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    text-align: center;
    color: var(--sl-color-gray-2);
  }

  .formula :global(span) {
    color: var(--sl-color-accent);
    font-weight: 500;
  }
</style>
