---
// Minimal footer: project name, license, GitHub link
---
<footer class="verikt-footer">
	<span>ver<span class="ikt">ikt</span></span>
	<span class="sep">&middot;</span>
	<a href="https://github.com/diktahq/verikt/blob/main/LICENSE" target="_blank" rel="noopener">Elastic License 2.0</a>
	<span class="sep">&middot;</span>
	<a href="https://github.com/diktahq/verikt" target="_blank" rel="noopener">GitHub</a>
</footer>

<style>
	.verikt-footer {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 1.5rem 1rem;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		border-top: 1px solid var(--sl-color-gray-5);
	}
	.ikt {
		color: var(--sl-color-accent);
	}
	.sep {
		color: var(--sl-color-gray-4);
	}
	.verikt-footer a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
	}
	.verikt-footer a:hover {
		color: var(--sl-color-accent);
	}
</style>
