{{- if eq .OrmLibrary "prisma" -}}
// Prisma schema — PostgreSQL
// Run: npx prisma migrate dev --name init
// Docs: https://www.prisma.io/docs/orm/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

