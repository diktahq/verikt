import { createCipheriv, createDecipheriv, randomBytes, scryptSync } from 'node:crypto'

const ALGORITHM = 'aes-256-gcm'
const KEY_LEN = 32   // 256 bits
const IV_LEN = 12    // 96 bits — GCM standard
const TAG_LEN = 16   // 128-bit auth tag

// deriveKey derives a 256-bit key from a passphrase using scrypt.
// Pass a consistent salt per deployment — store alongside the ciphertext is fine.
export function deriveKey(passphrase: string, salt: Buffer): Buffer {
  return scryptSync(passphrase, salt, KEY_LEN) as Buffer
}

// encrypt encrypts plaintext using AES-256-GCM.
// Returns a base64 string: salt(32) + iv(12) + tag(16) + ciphertext.
export function encrypt(plaintext: string, passphrase: string): string {
  const salt = randomBytes(KEY_LEN)
  const iv = randomBytes(IV_LEN)
  const key = deriveKey(passphrase, salt)

  const cipher = createCipheriv(ALGORITHM, key, iv)
  const encrypted = Buffer.concat([cipher.update(plaintext, 'utf8'), cipher.final()])
  const tag = cipher.getAuthTag()

  return Buffer.concat([salt, iv, tag, encrypted]).toString('base64')
}

// decrypt decrypts a value produced by encrypt().
// Throws if the ciphertext has been tampered with (auth tag mismatch).
export function decrypt(ciphertext: string, passphrase: string): string {
  const buf = Buffer.from(ciphertext, 'base64')

  const salt = buf.subarray(0, KEY_LEN)
  const iv = buf.subarray(KEY_LEN, KEY_LEN + IV_LEN)
  const tag = buf.subarray(KEY_LEN + IV_LEN, KEY_LEN + IV_LEN + TAG_LEN)
  const encrypted = buf.subarray(KEY_LEN + IV_LEN + TAG_LEN)

  const key = deriveKey(passphrase, salt)
  const decipher = createDecipheriv(ALGORITHM, key, iv)
  decipher.setAuthTag(tag)

  return decipher.update(encrypted) + decipher.final('utf8')
}
