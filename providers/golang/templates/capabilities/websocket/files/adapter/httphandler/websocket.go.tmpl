package httphandler

import (
	"context"
	"log/slog"
	"net/http"
	"sync"
	"time"

	"github.com/gorilla/websocket"
)

var upgrader = websocket.Upgrader{
	ReadBufferSize:  1024,
	WriteBufferSize: 1024,
	CheckOrigin: func(r *http.Request) bool {
		// Override with proper origin checking in production.
		return true
	},
}

// WSConn wraps a WebSocket connection with metadata.
type WSConn struct {
	Conn   *websocket.Conn
	ID     string
	cancel context.CancelFunc
}

// WSHub manages WebSocket connections.
type WSHub struct {
	mu     sync.RWMutex
	conns  map[string]*WSConn
	logger *slog.Logger
}

// NewWSHub creates a new WebSocket hub.
func NewWSHub(logger *slog.Logger) *WSHub {
	return &WSHub{
		conns:  make(map[string]*WSConn),
		logger: logger,
	}
}

// HandleWS upgrades HTTP to WebSocket and manages the connection.
func (h *WSHub) HandleWS(w http.ResponseWriter, r *http.Request) {
	conn, err := upgrader.Upgrade(w, r, nil)
	if err != nil {
		h.logger.Error("websocket upgrade failed", "error", err)
		return
	}

	ctx, cancel := context.WithCancel(r.Context())
	id := r.Header.Get("X-Request-ID")
	if id == "" {
		id = conn.RemoteAddr().String()
	}

	ws := &WSConn{Conn: conn, ID: id, cancel: cancel}

	h.mu.Lock()
	h.conns[id] = ws
	h.mu.Unlock()

	h.logger.Info("websocket connected", "id", id)

	defer func() {
		h.mu.Lock()
		delete(h.conns, id)
		h.mu.Unlock()
		cancel()
		conn.Close()
		h.logger.Info("websocket disconnected", "id", id)
	}()

	// Read loop.
	for {
		select {
		case <-ctx.Done():
			return
		default:
			conn.SetReadDeadline(time.Now().Add(60 * time.Second))
			_, _, err := conn.ReadMessage()
			if err != nil {
				return
			}
		}
	}
}

// Broadcast sends a message to all connected clients.
func (h *WSHub) Broadcast(ctx context.Context, message []byte) {
	h.mu.RLock()
	defer h.mu.RUnlock()

	for id, ws := range h.conns {
		if err := ws.Conn.WriteMessage(websocket.TextMessage, message); err != nil {
			h.logger.Warn("broadcast failed", "id", id, "error", err)
		}
	}
}

// Count returns the number of active connections.
func (h *WSHub) Count() int {
	h.mu.RLock()
	defer h.mu.RUnlock()
	return len(h.conns)
}
