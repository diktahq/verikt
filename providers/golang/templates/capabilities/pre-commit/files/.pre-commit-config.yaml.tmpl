repos:
{{- if .HasPreCommitHook}}
  - repo: local
    hooks:
{{- if .HasGolangCILint}}
      - id: golangci-lint
        name: golangci-lint
        entry: golangci-lint run
        language: system
        types: [go]
        pass_filenames: false
{{- end}}
{{- if .HasGofumpt}}
      - id: gofumpt
        name: gofumpt
        entry: gofumpt -w
        language: system
        types: [go]
{{- end}}
{{- end}}
{{- if .HasCommitMsgHook}}
  - repo: https://github.com/compilerla/conventional-pre-commit
    rev: v3.1.0
    hooks:
      - id: conventional-pre-commit
        stages: [commit-msg]
{{- end}}
