version: "2"
sql:
  - engine: "{{if .HasPostgreSQL}}postgresql{{else if .HasMySQL}}mysql{{else}}postgresql{{end}}"
    queries: "queries/"
    schema: "schema/"
    gen:
      go:
        package: "db"
        out: "adapter/db"
        sql_package: "pgx/v5"
        emit_json_tags: true
        emit_empty_slices: true
