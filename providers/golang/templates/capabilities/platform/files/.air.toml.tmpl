root = "."
tmp_dir = "tmp"

[build]
bin = "./tmp/main"
cmd = "go build -o ./tmp/main ./cmd/{{.ServiceName}}"
delay = 1000
exclude_dir = ["tmp", "vendor", "node_modules"]
exclude_regex = ["_test\\.go$"]
include_ext = ["go", "yaml", "yml"]
kill_delay = "2s"
log = "build-errors.log"
send_interrupt = true
stop_on_error = true

[log]
time = false

[misc]
clean_on_exit = true
