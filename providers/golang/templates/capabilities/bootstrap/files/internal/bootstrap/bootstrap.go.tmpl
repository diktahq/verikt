	{{.}}
{{- end}}
{{- end}}{{end}}
	app.OnShutdown("otel", lifecycle.ShutdownFunc(otelShutdown))

	logger.Info("starting {{.ServiceName}}",
		"version", version,
		"environment", cfg.App.Environment,
	)

	return app.Run(ctx)
}

func newLogger(cfg *config.Config) *slog.Logger {
	logger := observability.NewLogger(observability.LoggerConfig{
		Level:       cfg.Logger.Level,
		Format:      cfg.Logger.Format,
		ServiceName: cfg.App.Name,
	})

	redactHandler := observability.NewRedactHandler(
		logger.Handler(),
		observability.DefaultRedactConfig(),
	)

	return slog.New(redactHandler)
}

func newOTel(ctx context.Context, cfg *config.Config, version string) (func(context.Context) error, error) {
	return observability.InitProvider(ctx, observability.ProviderConfig{
		ServiceName:    cfg.App.Name,
		ServiceVersion: version,
		Environment:    cfg.App.Environment,
		EnableTraces:   true,
		EnableMetrics:  true,
	})
}
